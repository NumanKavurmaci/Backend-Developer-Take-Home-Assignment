# Local development credentials matching compose.yaml.
# Copy this file to .env for local development.
# Never commit real deployment credentials.

DATABASE_URL="postgresql://saatcms:saatcms_local@localhost:5432/saatcms?schema=public"
NODE_ENV="development"
DEPLOYMENT_ENV="local"

# Local/demo-only CMS bearer credentials. Replace these through a secret store
# in every shared environment.
CMS_API_KEYS="local-reader:reader:local-reader-key-0123456789abcdef0123456789,local-editor:editor:local-editor-key-0123456789abcdef012345678,local-admin:admin:local-admin-key-0123456789abcdef0123456789"
CMS_AUTH_ATTEMPT_LIMIT_PER_MINUTE="300"
CMS_RATE_LIMIT_PER_MINUTE="120"
CMS_MAX_BODY_BYTES="1048576"
CMS_MUTATIONS_ENABLED="true"

# Optional deployed-demo variables.
# Replace these only inside your private .env file.

# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# NODE_ENV="production"
# DEPLOYMENT_ENV="demo"
# DEMO_DATABASE_CONFIRMATION="HOST/DATABASE/public"
# DEPLOYMENT_URL="https://your-service.onrender.com"
