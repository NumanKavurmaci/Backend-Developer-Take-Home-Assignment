{
  "name": "saatcms-middleware-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SaatCMS OTT middleware core prototype.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:setup": "tsx scripts/db-setup.ts",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "tsx scripts/db-setup.ts",
    "db:migrate:prisma": "prisma migrate dev",
    "db:reset": "tsx scripts/db-setup.ts --reset",
    "db:studio": "prisma studio",
    "db:check": "tsx src/db/check.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@prisma/client": "5.22.0",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/sql.js": "^1.4.11",
    "prisma": "5.22.0",
    "sql.js": "^1.14.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
